# Hauska Spine Command Center — Environment Configuration
#
# Backend API endpoints. These are production defaults; override in .env.local
# for development (e.g., point to localhost during local development).

# Cortex API (Cloud Run) — operator run-state, place/atoms
VITE_CORTEX_API_URL=https://cortex-api-tds7av26va-uc.a.run.app

# Hauska MCP server — search_atoms, get_atom, admin introspection
VITE_MCP_URL=https://mcp.hauska.dev/mcp

# Retrieval API — atom trace / lineage (used by stubbed panels)
VITE_RETRIEVAL_API_URL=http://127.0.0.1:8080
