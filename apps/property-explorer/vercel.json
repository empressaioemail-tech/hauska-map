{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter property-explorer build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth?upath=$1" },
    { "source": "/api/spine-deep/(.*)", "destination": "/api/spine-deep?upath=$1" },
    { "source": "/api/spine/(.*)", "destination": "/api/spine?upath=$1" },
    { "source": "/api/pe-gtm", "destination": "/api/pe-gtm" },
    { "source": "/api/pe-billing", "destination": "/api/pe-billing" },
    { "source": "/api/pe-terrain-export", "destination": "/api/pe-terrain-export" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
