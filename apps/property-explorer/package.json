{
  "name": "property-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:renderer": "pnpm --filter @hauska/map-renderer build",
    "dev": "pnpm run build:renderer && vite --port 5175",
    "build": "pnpm run build:renderer && tsc --noEmit && vite build",
    "preview": "vite preview --port 5175",
    "test": "vitest run",
    "smoke:extension-handoff": "node scripts/extension-handoff-smoke.mjs"
  },
  "dependencies": {
    "@empressaio/cortex-client": "^0.1.2",
    "@empressaio/cortex-tiles": "^0.1.4",
    "@hauska/map-renderer": "workspace:*",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
